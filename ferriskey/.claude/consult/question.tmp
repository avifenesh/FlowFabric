```rust
use futures_util::{
    Stream, StreamExt,
    future::BoxFuture,
    task::{Context, Poll},
};
use std::pin::Pin;
use std::{borrow::Borrow, fmt, io};

use crate::pipeline::Pipeline;
use crate::value::{
    FromValue, Result, ToArgs, Write, from_owned_value,
};
use telemetrylib::FerrisKeySpan;

/// An argument to a valkey command
#[derive(Clone)]
pub(crate) enum Arg<D> {
    /// A normal argument
    Simple(D),
    /// A cursor position marker used in SCAN-family command argument lists.
    #[allow(dead_code)]
    Cursor,
}

/// Represents valkey commands.
#[derive(Clone)]
pub struct Cmd {
    data: Vec<u8>,
    // Arg::Simple contains the offset that marks the end of the argument
    args: Vec<Arg<usize>>,
    cursor: Option<u64>,
    span: Option<FerrisKeySpan>,
    is_fenced: bool,
    inflight_tracker: Option<crate::value::InflightRequestTracker>,
}

const FENCE_COMMAND: &[u8] = b"*1\r\n$4\r\nPING\r\n";

impl Write for Cmd {
    fn write_arg(&mut self, arg: &[u8]) {
        self.data.extend_from_slice(arg);
        self.args.push(Arg::Simple(self.data.len()));
    }
    fn write_arg_fmt(&mut self, arg: impl fmt::Display) {
        use std::io::Write;
        write!(self.data, "{arg}").unwrap();
        self.args.push(Arg::Simple(self.data.len()));
    }
}

impl Cmd {
    pub fn new() -> Cmd {
        Cmd {
            data: vec![],
            args: vec![],
            cursor: None,
            span: None,
            is_fenced: false,
            inflight_tracker: None,
        }
    }

    /// Returns the packed command as Bytes.
    #[inline]
    pub fn get_packed_command(&self) -> bytes::Bytes {
        let mut cmd = Vec::new();
        self.write_packed_command(&mut cmd);
        cmd.into()
    }

    pub(crate) fn write_packed_command(&self, cmd: &mut Vec<u8>) {
        write_command_to_vec(
            cmd,
            self.args_iter(),
            self.cursor.unwrap_or(0),
            self.is_fenced,
        )
    }

    pub(crate) fn write_packed_command_preallocated(&self, cmd: &mut Vec<u8>) {
        write_command(
            cmd,
            self.args_iter(),
            self.cursor.unwrap_or(0),
            self.is_fenced,
        )
        .unwrap()
    }

    /// Returns an iterator over the arguments
    pub(crate) fn args_iter(&self) -> impl Clone + ExactSizeIterator<Item = Arg<&[u8]>> {
        let mut prev = 0;
        self.args.iter().map(move |arg| match *arg {
            Arg::Simple(i) => {
                let arg = Arg::Simple(&self.data[prev..i]);
                prev = i;
                arg
            }
            Arg::Cursor => Arg::Cursor,
        })
    }

    pub(crate) fn arg_idx(&self, idx: usize) -> Option<&[u8]> {
        // ... (uses self.args and self.data)
    }
}
```

Key observations about the current design:
- `data: Vec<u8>` stores raw argument bytes concatenated
- `args: Vec<Arg<usize>>` stores end-offsets to reconstruct individual args
- `get_packed_command()` calls `write_command_to_vec()` which allocates a NEW Vec<u8> and serializes to RESP wire format, then converts to `Bytes`
- This means every command allocates twice: once for `data`, once for the RESP output
- `args_iter()` is used in 27 call sites for routing, telemetry, pubsub — it must keep working
- There is also `write_packed_command_preallocated()` for pipeline use where the Vec is pre-allocated externally

**Question:** What is the SIMPLEST way to eliminate the double allocation in the Cmd struct while keeping `args_iter()` functional?

Consider:
1. **OnceCell caching**: Add `packed: OnceCell<Bytes>` to Cmd. `get_packed_command()` calls `packed.get_or_init(|| { ... build RESP ... })`. Pros: zero-change to args_iter(), lazy, `Bytes` clone is free. Cons: Cmd becomes non-trivially-mut (can't call arg() after caching), but in practice commands are built then used, not modified. Is this actually the right simple answer?

2. **Return a view**: Can `get_packed_command()` somehow return a zero-copy view into `self.data`? The RESP framing (`*N\r\n$len\r\n...\r\n`) is NOT stored in `data` — only raw arg bytes are. So a zero-copy view is impossible without restructuring.

3. **Write RESP directly in arg()**: Instead of storing raw bytes + offsets, write the RESP bulk string framing (`$len\r\ndata\r\n`) directly into `data` during `arg()`, and store offset ranges that skip the framing for `args_iter()`. This would make `get_packed_command()` just prepend the `*N\r\n` header. Pros: single allocation. Cons: args_iter() needs to be updated to skip framing bytes, moderate refactor.

4. **Just use Bytes from the start**: Build a `Bytes` or `BytesMut` during arg() with RESP framing. Similar to option 3 but with `BytesMut`.

What would a senior Rust engineer do here with minimal fuss? The goal is minimal code changes, not an architectural rewrite. Which approach is actually simplest and correct?
